<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>LARA - PMO SaaS</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Segoe UI', Arial, sans-serif; 
      background: linear-gradient(135deg, #00BCD4 0%, #26C6DA 100%);
      min-height: 100vh; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      padding: 20px; 
    }
    .box { 
      background: white; 
      padding: 50px; 
      border-radius: 16px; 
      width: 100%; 
      max-width: 500px; 
      box-shadow: 0 20px 60px rgba(0,0,0,0.3); 
    }
    .header { 
      display: flex; 
      align-items: center; 
      gap: 15px; 
      margin-bottom: 30px; 
      padding-bottom: 20px; 
      border-bottom: 2px solid #E0F2F1;
    }
    .logo { 
      width: 100px; 
      height: 100px; 
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .logo img { 
      width: 100%; 
      height: 100%;
      object-fit: contain;
    }
    .brand h1 { 
      font-size: 1.8em; 
      color: #00897B; 
      margin: 0;
    }
    .brand p { 
      font-size: 0.9em; 
      color: #00BCD4; 
      margin: 5px 0 0 0;
    }
    .form-group { 
      margin-bottom: 20px; 
    }
    label { 
      display: block; 
      margin-bottom: 8px; 
      color: #333; 
      font-weight: 600;
    }
    input[type="file"], select { 
      width: 100%; 
      padding: 12px; 
      border: 2px solid #E0F2F1; 
      border-radius: 8px; 
      font-size: 1em;
      font-family: inherit;
    }
    input[type="file"]:focus, select:focus { 
      outline: none; 
      border-color: #00BCD4; 
      box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
    }
    button { 
      width: 100%; 
      padding: 12px; 
      background: linear-gradient(135deg, #00BCD4 0%, #26C6DA 100%); 
      color: white; 
      border: none; 
      border-radius: 8px; 
      font-size: 1em; 
      font-weight: 600; 
      cursor: pointer; 
      transition: all 0.3s;
    }
    button:hover:not(:disabled) { 
      transform: translateY(-2px); 
      box-shadow: 0 10px 20px rgba(0, 188, 212, 0.3);
    }
    button:disabled { 
      opacity: 0.6; 
      cursor: not-allowed;
    }
    .loading { 
      display: none; 
      text-align: center; 
      margin-top: 20px;
    }
    @keyframes spin { 
      0% { transform: rotate(0deg); } 
      100% { transform: rotate(360deg); }
    }
    .alert { 
      padding: 15px; 
      border-radius: 8px; 
      margin-top: 20px; 
      font-weight: 500;
    }
    .alert-error { 
      background-color: #FFEBEE; 
      color: #C62828; 
      border-left: 4px solid #C62828;
    }
    .alert-success { 
      background-color: #E8F5E9; 
      color: #2E7D32; 
      border-left: 4px solid #2E7D32;
    }
    #userInfo { 
      display: none; 
      text-align: right; 
      color: #00897B; 
      font-size: 0.9em; 
      margin-bottom: 20px;
    }
    #userInfo button { 
      width: auto; 
      padding: 8px 16px; 
      font-size: 0.85em; 
      margin-top: 10px;
    }
    
    #toast-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      pointer-events: none;
    }
    
    .toast {
      background: white;
      border-left: 4px solid #f59e0b;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 12px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
      max-width: 400px;
      pointer-events: auto;
      animation: slideInRight 0.3s ease-out;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    
    @keyframes slideInRight {
      from {
        transform: translateX(400px);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
    
    @keyframes slideOutRight {
      from {
        transform: translateX(0);
        opacity: 1;
      }
      to {
        transform: translateX(400px);
        opacity: 0;
      }
    }
    
    .toast.hide {
      animation: slideOutRight 0.3s ease-out forwards;
    }
    
    .toast-icon {
      font-size: 24px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    
    .toast-content {
      flex: 1;
    }
    
    .toast-title {
      font-weight: 600;
      color: #333;
      font-size: 14px;
      margin-bottom: 4px;
    }
    
    .toast-message {
      color: #666;
      font-size: 13px;
      line-height: 1.4;
    }
   </style>
</head>
<body>
  <div id="toast-container"></div>

  <div class="box">
    <div id="userInfo">
      <p>👋 Bienvenido, <strong id="userName"></strong></p>
      <button onclick="logout()">Cerrar sesión</button>
    </div>

    <div class="header">
      <div class="logo">
        <img src="logo.jpeg" alt="LARA Logo">
      </div>
      <div class="brand">
        <h1>LARA</h1>
        <p>Intelligence Accelerated</p>
      </div>
    </div>

    <form id="form">
      <div class="form-group">
        <label for="org">Nombre Organización</label>
        <input type="text" id="org" placeholder="Acme Corp" required>
      </div>

      <div class="form-group">
        <label for="file">Archivo Excel con Proyectos</label>
        <input type="file" id="file" accept=".xlsx" required>
      </div>

      <div class="form-group">
        <label for="fw">Metodología</label>
        <select id="fw" required>
          <option value="scrum">Scrum</option>
          <option value="kanban">Kanban</option>
          <option value="waterfall">Waterfall</option>
          <option value="safe">SAFe</option>
        </select>
      </div>

      <button type="submit" id="btn">🚀 EJECUTAR ANÁLISIS</button>
      <div class="loading" id="loading" style="display: none; text-align: center; margin-top: 20px;">
        <div style="border: 4px solid #f3f3f3; border-top: 4px solid #00BCD4; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 10px auto;"></div>
        <p id="status" style="color: #00BCD4; font-weight: 600; margin-top: 10px;">Procesando...</p>
      </div>
      <div id="alert" style="display: none;"></div>
    </form>
  </div>

  <!-- MODAL DE MAPEO DE COLUMNAS (Fase 3) -->
  <div id="mappingModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto;">
      <div style="background: linear-gradient(to right, #00BCD4, #26C6DA); color: white; padding: 24px; border-bottom: 1px solid #e0e0e0;">
        <h2 style="font-size: 1.5em; font-weight: bold; margin: 0;">Mapeo de Columnas</h2>
        <p style="font-size: 0.9em; margin: 8px 0 0 0; opacity: 0.9;">Confirma cómo mapeamos tus columnas a nuestros campos estándar</p>
      </div>

      <div style="padding: 24px;">
        <div style="background: #f5f5f5; border: 1px solid #ddd; border-radius: 8px; padding: 16px; margin-bottom: 16px;">
          <h3 style="font-size: 0.9em; font-weight: 600; color: #333; margin-bottom: 12px;">Vista Previa de Datos</h3>
          <div id="sampleDataPreview" style="font-size: 0.8em; overflow-x: auto;"></div>
        </div>

        <div id="mappingForm"></div>

        <div id="validationMessage" style="display: none; padding: 12px; border-radius: 8px; font-size: 0.9em; margin-top: 16px;"></div>
      </div>

      <div style="background: #f5f5f5; padding: 16px 24px; border-top: 1px solid #ddd; display: flex; justify-content: space-between; gap: 12px;">
        <button onclick="closeMappingModal()" style="background: #ccc; color: #333; padding: 10px 24px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
          Cancelar
        </button>
        <button onclick="confirmMapping()" id="confirmMappingBtn" style="background: linear-gradient(135deg, #00BCD4 0%, #26C6DA 100%); color: white; padding: 10px 24px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
          Confirmar Mapeo
        </button>
      </div>
    </div>
  </div>

  <div id="detectingSpinner" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 50; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 12px; padding: 32px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); text-align: center;">
      <div style="border: 4px solid #f3f3f3; border-top: 4px solid #00BCD4; border-radius: 50%; width: 48px; height: 48px; animation: spin 1s linear infinite; margin: 0 auto;"></div>
      <p style="margin-top: 16px; color: #333; font-weight: 600;">Analizando columnas con IA...</p>
    </div>
  </div>

  <script>
    function showToast(title, message) {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.innerHTML = `
        <div class="toast-icon">⚠️</div>
        <div class="toast-content">
          <div class="toast-title">${title}</div>
          <div class="toast-message">${message}</div>
        </div>
      `;
      container.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('hide');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 5000);
    }

    window.onload = async () => {
      const res = await fetch('/api/auth/me');
      if (!res.ok) { window.location = '/login'; return; }
      const data = await res.json();
      document.getElementById('userInfo').style.display = 'block';
      document.getElementById('userName').textContent = data.user.email;
    };

    function logout() {
      fetch('/api/auth/logout', { method: 'POST' }).then(() => {
        window.location = '/login';
      });
    }

    function showAlert(message, isError = false) {
      const alertDiv = document.getElementById('alert');
      alertDiv.className = isError ? 'alert alert-error' : 'alert alert-success';
      alertDiv.textContent = message;
      alertDiv.style.display = 'block';
    }

    // ========== FASE 3: MAPEO DE COLUMNAS ==========
    let currentDetectionState = {
      headers: [],
      sampleRows: [],
      suggestions: [],
      tempFilename: '',
      confirmedMapping: {},
    };

    document.getElementById('form').onsubmit = async (e) => {
      e.preventDefault();
      const file = document.getElementById('file').files[0];
      const btn = document.getElementById('btn');
      const loading = document.getElementById('loading');
      
      if (!file) {
        showAlert('❌ Por favor selecciona un archivo', true);
        return;
      }
      
      btn.disabled = true;
      loading.style.display = 'block';
      
      await handleMappingFileUpload(file);
      
      btn.disabled = false;
      loading.style.display = 'none';
    };

    async function handleMappingFileUpload(file) {
      const formData = new FormData();
      formData.append('file', file);

      const spinner = document.getElementById('detectingSpinner');
      spinner.style.display = 'flex';

      try {
        const token = localStorage.getItem('token');
        
        const response = await fetch('/api/data/mapping/detect-columns', {
          method: 'POST',
          body: formData,
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || 'Failed to detect columns');
        }

        const result = await response.json();
const detectionData = result.data;

currentDetectionState = {
  headers: detectionData.headers,
  sampleRows: detectionData.sampleRows,
  suggestions: detectionData.suggestions,
  tempFilename: detectionData.tempFilename,
  confirmedMapping: {},
        };

        populateMappingModal(detectionData);
        document.getElementById('mappingModal').style.display = 'flex';
      } catch (error) {
        console.error('Detection error:', error);
        showAlert('Error al detectar columnas: ' + error.message, true);
      } finally {
        spinner.style.display = 'none';
      }
    }

    function populateMappingModal(data) {
      const previewDiv = document.getElementById('sampleDataPreview');
      previewDiv.innerHTML = '';

      let html = '<table style="width: 100%; border-collapse: collapse; font-size: 0.8em;">';
      html += '<thead><tr style="background: #e0e0e0;">';
      data.headers.forEach((h) => {
        html += `<th style="border: 1px solid #ccc; padding: 8px; text-align: left; font-weight: 600;">${h}</th>`;
      });
      html += '</tr></thead><tbody>';

      data.sampleRows.forEach((row) => {
        html += '<tr>';
        data.headers.forEach((h) => {
          const val = String(row[h] || '').substring(0, 30);
          html += `<td style="border: 1px solid #ccc; padding: 8px;">${val}</td>`;
        });
        html += '</tr>';
      });

      html += '</tbody></table>';
      previewDiv.innerHTML = html;

      const formDiv = document.getElementById('mappingForm');
      formDiv.innerHTML = '';

      data.headers.forEach((header) => {
        const suggestion = data.suggestions.find((s) => s.originalHeader === header);
        console.log(`Header: "${header}" => Suggestion:`, suggestion);

        const fieldOptions = [
  { value: null, label: '(No mapear)' },
  { value: 'project_name', label: 'Nombre de Proyecto *' },
  { value: 'status', label: 'Estado del Proyecto' },
  { value: 'estimated_cost', label: 'Costo Estimado' },
  { value: 'actual_cost', label: 'Costo Real' },
  { value: 'progress_percent', label: 'Progreso (%)' },
  { value: 'start_date', label: 'Fecha Inicio' },
  { value: 'end_date', label: 'Fecha Fin' },
  { value: 'risks', label: 'Riesgos Identificados' },

        ];

        const div = document.createElement('div');
        div.style.cssText = 'display: flex; align-items: center; gap: 12px; padding: 12px; background: white; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 12px;';

        const label = document.createElement('label');
        label.style.cssText = 'width: 30%; font-weight: 600; font-size: 0.9em; color: #333;';
        label.textContent = `"${header}"`;

        const select = document.createElement('select');
        select.style.cssText = 'flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9em;';
        select.dataset.originalHeader = header;

        fieldOptions.forEach((opt) => {
          const option = document.createElement('option');
          option.value = opt.value === null ? '' : opt.value;
          option.textContent = opt.label;
          option.selected = suggestion?.suggestedField === opt.value;
          select.appendChild(option);
        });

        const reasoning = document.createElement('span');
        reasoning.style.cssText = 'width: 30%; font-size: 0.8em; color: #666; font-style: italic;';
        if (suggestion) {
          reasoning.textContent = `(${(suggestion.confidence * 100).toFixed(0)}%) ${suggestion.reasoning || ''}`;
        }

        div.appendChild(label);
        div.appendChild(select);
        div.appendChild(reasoning);
        formDiv.appendChild(div);

        currentDetectionState.confirmedMapping[header] = suggestion?.suggestedField || null;
      });
    }

 function buildConfirmedMapping() {
  const mapping = {};
  const selects = document.querySelectorAll('#mappingForm select');
  selects.forEach((select) => {
    const originalHeader = select.dataset.originalHeader;
    const value = select.value;
    mapping[originalHeader] = value || null;
  });
  return mapping;
}

function validateMapping(mapping) {
  const errors = [];
  const hasProjectName = Object.values(mapping).includes('project_name');
  if (!hasProjectName) {
    errors.push('Debes mapear al menos el campo "Nombre de Proyecto" (obligatorio)');
  }
  return errors;
}

    async function confirmMapping() {
      const mapping = buildConfirmedMapping();
      const errors = validateMapping(mapping);

      if (errors.length > 0) {
        showValidationMessage('error', errors.join('\n'));
        return;
      }

      const btn = document.getElementById('confirmMappingBtn');
      btn.disabled = true;
      btn.textContent = 'Guardando...';

      try {
        const token = localStorage.getItem('token');
        
        const response = await fetch('/api/data/mapping/save-mapping', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            tempFilename: currentDetectionState.tempFilename,
            confirmedMapping: mapping,
          }),
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || 'Failed to save mapping');
        }

        const result = await response.json();

        closeMappingModal();
        showAlert('✅ Mapeo guardado exitosamente. Redirigiendo...', false);

        setTimeout(() => {
          window.location.href = '/projects';
        }, 1500);
      } catch (error) {
        console.error('Save error:', error);
        showValidationMessage('error', 'Error al guardar mapeo: ' + error.message);
        btn.disabled = false;
        btn.textContent = 'Confirmar Mapeo';
      }
    }

    function closeMappingModal() {
      document.getElementById('mappingModal').style.display = 'none';
      document.getElementById('mappingForm').innerHTML = '';
      document.getElementById('sampleDataPreview').innerHTML = '';
    }

    function showValidationMessage(type, message) {
      const msgDiv = document.getElementById('validationMessage');
      if (type === 'error') {
        msgDiv.style.background = '#FFEBEE';
        msgDiv.style.color = '#C62828';
        msgDiv.style.borderLeft = '4px solid #C62828';
      } else {
        msgDiv.style.background = '#E8F5E9';
        msgDiv.style.color = '#2E7D32';
        msgDiv.style.borderLeft = '4px solid #2E7D32';
      }
      msgDiv.textContent = message;
      msgDiv.style.display = 'block';
    }
  </script>

</body>
</html>